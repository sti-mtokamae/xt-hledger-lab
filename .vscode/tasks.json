{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "clj-xtdb",
      "type": "shell",
      "command": "clj",
      "args": ["-A:xtdb"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Clojure",
          "endsPattern": "^user=>"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
